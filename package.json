{
  "name": "nymphicus-website",
  "version": "0.1.0",
  "private": true,
  "description": "Static marketing site for Nymphi — visual AI agent builder platform",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev.ps1",
    "dev:3001": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev.ps1 -Port 3001",
    "dev:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev.ps1 -Clean",
    "dev:3001:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev.ps1 -Port 3001 -Clean",
    "sync:mcp-icons": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-mcp-icons.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
